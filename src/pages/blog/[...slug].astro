---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <article class="w-full">
    
    {entry.data.image && (
      <div class="max-w-5xl mx-auto px-4 sm:px-6 mt-8">
        <div class="aspect-[3/1] overflow-hidden rounded-lg border border-white/20">
          <img 
            src={entry.data.image} 
            alt={entry.data.title} 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    )}
    
    <div class="max-w-3xl mx-auto px-6 py-10 sm:py-14">
      
      <header class="mb-10 border-b border-white/10 pb-8">
        <div class="flex flex-wrap items-center gap-5 mb-6">
          <time class="font-mono-text text-[0.8rem] font-bold tracking-widest text-white/60 uppercase">
            {entry.data.date.toLocaleDateString('en-US', {
              month: '2-digit',
              day: '2-digit',
              year: 'numeric'
            }).replace(/\//g, '.')}
          </time>
          
          {entry.data.tags && (
            <div class="flex gap-4">
              {entry.data.tags.map(tag => (
                <span class="font-pixel-text text-[0.85rem] text-aqua-glow uppercase tracking-wider">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </div>

        <h1 class="text-3xl sm:text-5xl font-bold text-white leading-tight tracking-tight">
          {entry.data.title}
        </h1>
      </header>

      <div class="main-content !p-0 !bg-transparent">
        <Content />
      </div>
      
      <footer class="mt-20 pt-10 border-t border-white/10">
        <a 
          href="/blog" 
          class="font-mono-text text-[0.8rem] font-bold text-white/30 hover:text-white transition-colors uppercase tracking-widest no-underline"
        >
          ← Return to Blog Index
        </a>
      </footer>
    </div>
  </article>
</Layout>