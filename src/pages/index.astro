---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SidebarBox from '../components/SidebarBox.astro';

const posts = (
  await getCollection(
    'blog',
    ({ data }) => !import.meta.env.PROD || !data.draft,
  )
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Layout>
  <!-- Welcome Section -->
  <div class="mb-8">
    <h2>Welcome</h2>
    <div class="space-y-4">
      <p>
        Welcome to my personal website! This place is meant to serve as a secret
        getaway for myself, separate from other ongoing projects that may have more,
        um... corporate incentive for existing.
      </p>
      <p>
        This project was half an experiment and half of something that I've been
        wanting to make for a long time. If you're curious about the tech, it was
        made with a combination of <a href="https://astro.build/" target="_blank"
          >Astro</a
        > and this open-source CMS called <a
          href="https://github.com/sveltia/sveltia-cms"
          target="_blank">Sveltia</a
        >. Pretty neat stuff!
      </p>
    </div>
  </div>

  <!-- Latest Posts Section -->
  <div class="mb-8">
    <h2 class="mb-4">Latest Posts</h2>
    <div class="space-y-3">
      {posts.map(post => (
        <a
          href={`/blog/${post.slug}`}
          class="block p-4 border border-white/10 rounded hover:border-white/30 hover:bg-white/5 transition-colors"
        >
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <span class="font-medium text-white">{post.data.title}</span>
            <time class="text-xs font-mono-text text-white/60 whitespace-nowrap">
              {post.data.date.toLocaleDateString('en-GB').replace(/\//g, '.')}
            </time>
          </div>
          {post.data.tags?.[0] && (
            <p class="text-xs text-white/50 mt-2">#{post.data.tags[0]}</p>
          )}
        </a>
      ))}
    </div>
    <a href="/blog" class="inline-block mt-6 text-sm hover:underline">View all posts →</a>
  </div>

  <!-- Misc Section -->
  <SidebarBox title="OTHER STUFF">
    <div class="space-y-3">
      <div>
        <p class="text-xs font-mono-text text-white/60 mb-1">STATUS</p>
        <p class="text-sm">Under active development</p>
      </div>
      <div>
        <p class="text-xs font-mono-text text-white/60 mb-1">INTERESTS</p>
        <p class="text-sm">Web design, creative coding, music</p>
      </div>
      <div>
        <p class="text-xs font-mono-text text-white/60 mb-1">CURRENTLY</p>
        <p class="text-sm">Rebuilding & redesigning this space</p>
      </div>
    </div>
  </SidebarBox>
</Layout>
