---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SidebarBox from '../components/SidebarBox.astro';

const [blogPosts, readingPosts, gamesPosts] = await Promise.all([
  getCollection('blog'),
  getCollection('reading'),
  getCollection('games'),
]);

const latestPosts = [...blogPosts, ...readingPosts, ...gamesPosts]
  .filter((p) => !import.meta.env.PROD || !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Layout>
  <!-- Welcome Section -->
  <section class="glass-panel mb-8 max-w-7xl mx-auto">
    <div class="space-y-4">
      <h2>Welcome</h2>
      <p>
        Welcome to my personal website! This place is meant to serve as a secret
        getaway for myself, separate from other ongoing projects that may have
        more, um... corporate incentive for existing.
      </p>
      <p>
        This project was half an experiment and half of something that I've been
        wanting to make for a long time. If you're curious about the tech, it
        was made with a combination of <a
          href="https://astro.build/"
          target="_blank"
          rel="noreferrer"
          class="text-sky-200 hover:text-sky-100 transition-colors"
          >Astro</a
        > and this open-source CMS called <a
          href="https://github.com/sveltia/sveltia-cms"
          target="_blank"
          rel="noreferrer"
          class="text-sky-200 hover:text-sky-100 transition-colors"
          >Sveltia</a
        >.
      </p>
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="glass-panel mb-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2>Latest Posts</h2>
        <p class="text-sm text-slate-400 mt-1">A quick snapshot of the freshest writing, reading, and games.</p>
      </div>
      <div class="flex flex-wrap justify-end gap-3">
        <a href="/blog" class="text-sm text-slate-200 hover:text-white transition">View Journal →</a>
        <a href="/reading" class="text-sm text-slate-200 hover:text-white transition">View Reading List →</a>
      </div>
    </div>

    <div class="mt-6 grid gap-4 lg:grid-cols-2">
      {
        latestPosts.map((post) => {
          const isReading = post.collection === 'reading';
          const isGame = post.collection === 'games';
          let tag = null;
          if ('tags' in post.data) {
            tag = post.data.tags?.[0];
          } else if (isReading) {
            tag = 'Reading';
          } else if (isGame) {
            tag = 'Gaming';
          }
          const description = post.data.description;

          return (
            <a
              href={`/${post.collection}/${post.slug}`}
              class="group block overflow-hidden rounded-3xl border border-slate-200/15 bg-slate-900/70 p-5 shadow-xl shadow-slate-950/20 transition hover:bg-slate-900/85"
            >
              <div class="flex items-center justify-between gap-3 mb-3">
                <span class="font-semibold text-white text-lg group-hover:text-sky-200 transition-colors">
                  {post.data.title}
                </span>
                <time class="text-xs font-mono text-slate-200 whitespace-nowrap">
                  {post.data.date
                    .toLocaleDateString('en-US', {
                      month: 'numeric',
                      day: 'numeric',
                      year: 'numeric',
                    })
                    .replace(/\//g, '.')}
                </time>
              </div>

              {description && (
                <p class="text-sm text-slate-300 leading-relaxed line-clamp-3">
                  {description}
                </p>
              )}

              {tag && (
                <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-slate-200/10 bg-white/5 px-3 py-1 text-xs uppercase tracking-widest text-slate-300">
                  <span class={isReading || isGame ? 'text-sky-200' : 'text-slate-300'}>#{tag}</span>
                </div>
              )}
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- Misc Section -->
  <SidebarBox title="OTHER STUFF">
    <div class="space-y-4">
      <div>
        <p class="text-xs uppercase tracking-widest text-slate-400 mb-1">STATUS</p>
        <p class="text-sm">Under active development</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-slate-400 mb-1">INTERESTS</p>
        <p class="text-sm">Web design, creative coding, music</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-slate-400 mb-1">CURRENTLY</p>
        <p class="text-sm">Rebuilding & redesigning this space</p>
      </div>
    </div>
  </SidebarBox>
</Layout>
