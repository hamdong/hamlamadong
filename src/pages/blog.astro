---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (
  await getCollection(
    'blog',
    ({ data }) => !import.meta.env.PROD || !data.draft,
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = Array.from(
  new Set(posts.flatMap((post) => post.data.tags || [])),
).sort();
---

<Layout title="Blog">
  <div class="w-full">
    <header class="mb-6 border-b border-white/10">
      <h2>Blog</h2>
    </header>

    <div class="mb-8 pb-6 border-b border-white/10">
      <p class="text-xs font-mono-text text-white/70 uppercase tracking-wider mb-3">
        Filter by tag
      </p>
      <div class="flex flex-wrap gap-2">
        <button type="button" data-filter="all" class="filter-btn active">[ ALL ]</button>
        {allTags.map((tag) => (
          <button type="button" data-filter={tag} class="filter-btn">
            [ {tag.toUpperCase()} ]
          </button>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}`}
          data-tags={post.data.tags?.join(',')}
          class="post-item group flex flex-col rounded-lg border border-white/20 bg-white/5 transition-colors hover:border-white/60 hover:bg-white/10 overflow-hidden"
        >
          <div class="relative aspect-[4/3] overflow-hidden border-b border-white/20">
            {post.data.image && (
              <img
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
            )}
          </div>

          <div class="p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <time class="font-mono-text text-[0.8rem] font-bold text-white/60">
                {post.data.date
                  .toLocaleDateString('en-US', {
                    month: '2-digit',
                    day: '2-digit',
                    year: 'numeric',
                  })
                  .replace(/\//g, '.')}
              </time>

              {post.data.tags?.[0] && (
                <span class="font-pixel-text text-[0.75rem] text-aqua-glow uppercase tracking-wider">
                  #{post.data.tags[0]}
                </span>
              )}
            </div>

            <h3 class="font-bold text-[1.1rem] leading-tight text-white group-hover:text-aqua-glow transition-colors m-0">
              {post.data.title}
            </h3>

            <div class="mt-1">
              <span class="text-[0.7rem] font-mono-text font-bold text-white/40 uppercase tracking-widest">
                Read Entry →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {!posts.length && <p class="mono-text">No blogs detected.</p>}
  </div>
</Layout>

<style>
  .filter-btn {
    font-family: var(--font-pixel);
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.25rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.2s;
    cursor: pointer;
    background: transparent;
  }
  .filter-btn:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
    background-color: rgba(255, 255, 255, 0.08);
  }
  .filter-btn.active {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
  }
  .post-item.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
    const postItems = document.querySelectorAll('.post-item') as NodeListOf<HTMLAnchorElement>;

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const selectedFilter = button.dataset.filter ?? '';
        filterButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');
        postItems.forEach((post) => {
          if (selectedFilter === 'all') {
            post.classList.remove('hidden');
          } else {
            const postTags = (post.dataset.tags ?? '').split(',').filter(Boolean);
            post.classList.toggle('hidden', !postTags.includes(selectedFilter));
          }
        });
      });
    });
  });
</script>