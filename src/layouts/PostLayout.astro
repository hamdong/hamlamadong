---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

interface Props {
  entry: CollectionEntry<'blog'> | CollectionEntry<'reading'>;
  collectionName: 'blog' | 'reading';
}

const { entry, collectionName } = Astro.props;

let tags: string[] | undefined = undefined;
if (entry.collection === 'blog') {
  tags = entry.data.tags;
}

const rating = entry.collection === 'reading' ? entry.data.rating : undefined;
const stars = rating ? '★'.repeat(rating) + '☆'.repeat(5 - rating) : null;
const isReading = collectionName === 'reading';
---

<Layout title={entry.data.title}>
  <article class="w-full">
    {
      !isReading && entry.data.image && (
        <div class="max-w-5xl mx-auto px-4 sm:px-6 mt-8">
          <div class="aspect-[3/1] overflow-hidden rounded-lg border border-white/20">
            <img
              src={entry.data.image}
              alt={entry.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      )
    }

    <div class="max-w-3xl mx-auto px-6 py-10 sm:py-14">
      <header class="mb-10 border-b border-white/10 pb-8">
        <div class="flex flex-wrap items-center gap-5 mb-6">
          <time
            class="font-mono-text text-[0.8rem] font-bold tracking-widest text-white/60 uppercase"
          >
            {
              entry.data.date
                .toLocaleDateString('en-US', {
                  month: 'numeric',
                  day: 'numeric',
                  year: 'numeric',
                })
                .replace(/\//g, '.')
            }
          </time>

          {
            tags && tags.length > 0 ? (
              <div class="flex gap-4">
                {tags.map((tag) => (
                  <span class="font-pixel-text text-[0.85rem] text-aqua-glow uppercase tracking-wider">
                    #{tag}
                  </span>
                ))}
              </div>
            ) : (
              <span class="font-pixel-text text-[0.85rem] text-white/40 uppercase tracking-wider">
                📖 {collectionName}
              </span>
            )
          }
        </div>

        <h1
          class="text-3xl sm:text-5xl font-bold text-white leading-tight tracking-tight mb-4"
        >
          {entry.data.title}
        </h1>

        {
          stars && (
            <div class="flex items-center gap-2">
              <span class="text-yellow-400 font-mono-text tracking-widest text-lg">
                {stars}
              </span>
              <span class="font-pixel-text text-[0.7rem] text-white/40 uppercase">
                ({rating}/5)
              </span>
            </div>
          )
        }
      </header>

      <div class="main-content !p-0 !bg-transparent overflow-hidden">
        {
          isReading && entry.data.image && (
            <div class="float-right ml-6 mb-4 w-32 sm:w-40 lg:w-48">
              <div class="aspect-[2/3] overflow-hidden rounded border border-white/10 bg-white/5 shadow-lg">
                <img
                  src={entry.data.image}
                  alt={entry.data.title}
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          )
        }

        <slot />
      </div>

      <footer class="mt-20 pt-10 border-t border-white/10">
        <a
          href={`/${collectionName}`}
          class="font-mono-text text-[0.8rem] font-bold text-white/30 hover:text-white transition-colors uppercase tracking-widest no-underline"
        >
          ← Return to {
            collectionName.charAt(0).toUpperCase() + collectionName.slice(1)
          } Index
        </a>
      </footer>
    </div>
  </article>
</Layout>
