---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import InteractiveGrass from '../components/InteractiveGrass.astro';
import CloudLayer from '../components/CloudLayer.astro';
import FishTank from '../components/FishTank.astro';

const { title = 'Hamlamadong' } = Astro.props;
const navLinks = [
  { href: '/', label: 'HOME' },
  { href: '/blog', label: 'BLOG' },
  { href: '#', label: 'ART', disabled: true },
  { href: '/games', label: 'GAMES' },
  { href: '/reading', label: 'READING' },
  { href: '/about', label: 'ABOUT' },
];

const navBase = 'font-pixel text-sm sm:text-base transition-colors';
const navActive = 'text-sky-200 hover:text-white';
const navDisabled = 'text-slate-400 pointer-events-none line-through';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono&family=VT323&family=Inter:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative min-h-screen">
    <CloudLayer />

    <div class="relative mx-auto max-w-8xl px-4 sm:px-6 pt-6 pb-10">
      <div class="mx-auto max-w-7xl">
        <header class="mb-8">
          <div class="flex flex-col gap-4">
            <div>
              <h1 class="text-white text-3xl sm:text-4xl font-semibold uppercase tracking-widest">
                <a href="/">HAMLAMADONG</a>
              </h1>
            </div>
            <nav class="flex flex-wrap gap-3 sm:gap-4">
              {
                navLinks.map((link) => (
                  <a
                    href={link.href}
                    class={`${navBase} ${link.disabled ? navDisabled : navActive}`}
                  >
                    {link.label}
                  </a>
                ))
              }
            </nav>
          </div>
        </header>

        <main class="space-y-8">
          <slot />
        </main>

        <Footer />
      </div>
    </div>

    <FishTank />
    <InteractiveGrass />
  </body>
</html>
