---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import InteractiveGrass from '../components/InteractiveGrass.astro';
import CloudLayer from '../components/CloudLayer.astro';
import FishTank from '../components/FishTank.astro';

const { title = 'Hamlamadong' } = Astro.props;
const navLinks = [
  { href: '/', label: 'HOME' },
  { href: '/blog', label: 'BLOG' },
  { href: '#', label: 'ART', disabled: true },
  { href: '/games', label: 'GAMES' },
  { href: '/reading', label: 'READING' },
  { href: '/about', label: 'ABOUT' },
];

const linkStyle =
  'font-pixel-text text-sm sm:text-base no-underline transition-colors';
const activeStyle = 'text-aqua-glow hover:text-white';
const disabledStyle = 'text-white/30 pointer-events-none line-through';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono&family=VT323&family=Inter:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative font-sans">
    <CloudLayer />
    <!-- Header with Title and Top Navigation -->
    <header class="mx-auto mt-5 mb-2.5 max-w-7xl px-4 sm:px-6">
      <div class="flex flex-col gap-4">
        <h1
          class="text-white text-3xl sm:text-4xl font-bold tracking-[2px]"
          style="font-family: 'Inter', sans-serif;"
        >
          <a href="/" class="no-underline">HAMLAMADONG</a>
        </h1>

        <!-- Top Navigation -->
        <nav class="flex flex-wrap gap-3 sm:gap-4">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class={`${linkStyle} ${link.disabled ? disabledStyle : activeStyle}`}
              >
                [ {link.label} ]
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <FishTank />

    <!-- Main Content Container -->
    <div class="mx-auto mb-10 max-w-7xl px-4 sm:px-6" transition:animate="none">
      <!-- Main Content Area -->
      <main
        class="w-full border border-white/10 rounded-lg overflow-hidden"
        transition:animate="fade"
      >
        <div class="main-content w-full">
          <slot />
          <Footer />
        </div>
      </main>
    </div>
    <InteractiveGrass />
  </body>
</html>
