---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import SidebarBox from '../components/SidebarBox.astro';
import '../styles/global.css';

const { title = 'Hamlamadong' } = Astro.props;
const posts = (
  await getCollection(
    'blog',
    ({ data }) => !import.meta.env.PROD || !data.draft,
  )
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono&family=VT323&family=Inter:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="external-brand">
      <a href="/"><h1>HAMLAMADONG</h1></a>
    </header>

    <div class="app-shell" transition:animate="none">
      <aside class="sidebar" transition:persist>
        <SidebarBox title="PROFILE">
          <div class="mono-text">
            <p>📍 Earth</p>
            <p>🎧 Rush</p>
          </div>
        </SidebarBox>

        <SidebarBox title="LINKS">
          <nav class="pixel-nav">
            <a href="/">[ HOME ]</a>
            <a href="/blog">[ BLOG ]</a>
            <a href="#" style="pointer-events: none">[̶ ̶A̶R̶T̶ ̶]̶</a>
            <a href="#" style="pointer-events: none">[̶̶̶ ̶̶̶A̶B̶O̶U̶T̶ ̶M̶E̶ ̶̶̶]̶̶̶</a>
          </nav>
        </SidebarBox>

        <SidebarBox title="RECENT">
          <ul class="archive-list">
            {
              posts.map((p) => (
                <li>
                  <a href={`/blog/${p.slug}`}>» {p.data.title}</a>
                </li>
              ))
            }
          </ul>
        </SidebarBox>

        <SidebarBox title="MISC">
          <div class="mono-text" style="opacity: 0.5;">
            // UNDER<br />
            // CONSTRUCTION
          </div>
        </SidebarBox>
      </aside>

      <main class="main-panel" transition:animate="fade">
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  .external-brand {
    max-width: 1100px;
    margin: 20px auto 10px;
    padding: 0 1.5rem;
  }
  .external-brand h1 {
    font-family: var(--font-pixel);
    color: #fff;
    letter-spacing: 4px;
    text-shadow: 0 0 15px rgba(0, 242, 255, 0.4);
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .app-shell {
    max-width: 1100px;
    margin: 0 auto 40px;
    display: flex;
    min-height: 80vh;
    border: 1px solid var(--border-shine);
    border-radius: 12px;
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    background: #13347580;
  }

  .sidebar {
    width: 260px;
    padding: 25px;
    background: rgba(47, 72, 155, 0.4);
    border-right: 1px solid var(--border-shine);
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex-shrink: 0;
  }

  .main-panel {
    flex: 1;
    padding: 40px;
    background: rgba(64, 112, 218, 0.1);
  }

  .main-panel p a {
    color: var(--aqua-glow);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 242, 255, 0.3);
    transition: all 0.2s ease;
  }

  .main-panel p a:hover {
    color: #fff;
    border-bottom-color: #fff;
    text-shadow: 0 0 10px rgba(0, 242, 255, 0.8);
    background: rgba(0, 242, 255, 0.1);
  }

  .pixel-nav a {
    display: block;
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--aqua-glow);
    text-decoration: none;
  }
  .pixel-nav a:hover {
    color: #fff;
    transform: translateX(2px);
    transition: 0.2s;
  }
  .archive-list {
    list-style: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #fff;
  }
  .archive-list a {
    color: inherit;
    text-decoration: none;
    display: block;
    margin-bottom: 4px;
  }
</style>
