---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="mb-8 pb-6 border-b border-slate-200/15">
  <p class="text-xs font-mono uppercase tracking-widest text-slate-400 mb-3">
    Filter by tag
  </p>
  <div class="flex flex-wrap gap-2">
    <button
      type="button"
      data-filter="all"
      class="filter-btn font-pixel text-xs uppercase tracking-widest text-slate-200 border border-slate-200/20 rounded-full px-3 py-2 transition duration-200 bg-slate-800/50 hover:border-slate-100/60 hover:bg-slate-800/70 active:bg-slate-800/80"
    >
      ALL
    </button>
    {
      tags.map((tag) => (
        <button
          type="button"
          data-filter={tag}
          class="filter-btn font-pixel text-xs uppercase tracking-widest text-slate-200 border border-slate-200/20 rounded-full px-3 py-2 transition duration-200 bg-slate-800/50 hover:border-slate-100/60 hover:bg-slate-800/70 active:bg-slate-800/80"
        >
          {tag.toUpperCase()}
        </button>
      ))
    }
  </div>
</div>
