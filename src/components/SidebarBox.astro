---
const { title } = Astro.props;
---

<section class="glass-panel overflow-hidden">
  <div class="border-b border-white/10 px-5 py-3">
    <span class="text-xs uppercase tracking-widest text-slate-400">
      {title}
    </span>
  </div>
  <div class="space-y-4 px-5 py-5">
    <slot />
  </div>
</section>
