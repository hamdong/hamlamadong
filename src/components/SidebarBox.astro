---
const { title } = Astro.props;
---
<section class="aero-box">
  <header class="aero-header">
    <span class="title-text">{title}</span>
  </header>
  <div class="aero-content">
    <slot />
  </div>
</section>

<style>
  .aero-box {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-shine);
    border-radius: 4px;
    overflow: hidden;
  }
  .aero-header {
    background: linear-gradient(to bottom, rgba(255,255,255,0.1), transparent);
    background-color: rgba(255, 255, 255, 0.05);
    padding: 6px 12px;
    position: relative;
    border-bottom: 1px solid var(--border-shine);
  }
  .title-text {
    font-size: 0.7rem; font-weight: 700; color: #fff;
    text-transform: uppercase; letter-spacing: 1px; font-family: var(--font-mono);
  }
  .aero-content { padding: 12px; }
</style>